# ============================================================
# AI Toolkit — Environment Variables
#
# 1. Get your FREE Groq API key at: https://console.groq.com/keys
# 2. Copy this file to .env.local  (never commit .env.local!)
# 3. Replace 'your_key_here' with your actual key
# 4. Restart the dev server
#
# Without this key, the app runs in DEMO MODE with
# simulated AI responses — still great for learning!
# ============================================================

VITE_GROQ_API_KEY=your_groq_api_key_here
